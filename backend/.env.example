# ============================================================
# REFCON - Contoh Konfigurasi Environment
# Salin file ini menjadi .env dan isi sesuai lingkungan Anda
# JANGAN commit file .env ke repository (sudah di .gitignore)
# ============================================================

# ----------------------------
# Database MySQL
# ----------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=refcon_db
DB_USER=refcon_user
DB_PASSWORD=ganti_dengan_password_anda

# ----------------------------
# FastAPI Server
# ----------------------------
APP_HOST=127.0.0.1
APP_PORT=8000

# ----------------------------
# SMTP (Email Reminder)
# ----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email_anda@gmail.com
SMTP_PASSWORD=app_password_gmail_anda
